---
import SectionHeading from './SectionHeading.astro';
import { historyData } from '../data/history';
import { t, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ja' } = Astro.props;
---

<section id="history" class="relative bg-white scroll-mt-16">
  <div class="absolute top-4 right-4 text-[10px] font-mono text-gray-400">
    SECTION: LOGS // ID: 004
  </div>

  <div class="max-w-screen-xl mx-auto px-4 md:px-16 py-20 reveal">
    <SectionHeading number="04" title="History & Achievements" class="mb-12" />

    <div class="overflow-x-auto border border-grid">
      <table class="w-full text-left border-collapse text-sm">
        <thead class="bg-gray-50 text-gray-500 font-mono text-xs uppercase tracking-wider border-b border-grid">
          <tr>
            <th class="px-2 py-3 md:p-4 w-[1%] whitespace-nowrap border-r border-grid text-[10px] md:text-xs">Date</th>
            <th class="px-2 py-3 md:p-4 w-[1%] whitespace-nowrap border-r border-grid text-[10px] md:text-xs">Type</th>
            <th class="px-2 py-3 md:p-4 border-r border-grid text-[10px] md:text-xs">Title / Event</th>
            <th class="p-4 hidden md:table-cell">Detail</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-grid text-gray-700">
          {historyData.map((item) => (
            <tr class="hover:bg-gray-50/50 transition-colors group">
              
              <td class="px-2 py-3 md:p-4 font-mono text-gray-500 border-r border-grid whitespace-nowrap text-xs md:text-sm">
                {item.date}
              </td>

              <td class="px-2 py-3 md:p-4 border-r border-grid whitespace-nowrap">
                <span class={`inline-block px-1.5 py-0.5 md:px-2 text-[10px] border rounded font-mono
                  ${item.type === 'Award' ? 'text-amber-700 border-amber-200 bg-amber-50' :
                    item.type === 'Research' ? 'text-blue-700 border-blue-200 bg-blue-50' :
                    item.type === 'Experience' ? 'text-emerald-700 border-emerald-200 bg-emerald-50' :
                    item.type === 'Publication' ? 'text-purple-700 border-purple-200 bg-purple-50' :
                    'text-gray-600 border-gray-200 bg-gray-100'}`}>
                  {item.type}
                </span>
              </td>

              <td class="p-4 font-bold group-hover:text-primary transition-colors border-r border-grid">
                {t(item.title, lang)}
                <div class="md:hidden text-xs text-gray-400 font-normal mt-1">{t(item.detail, lang)}</div>
              </td>

              <td class="p-4 text-gray-500 hidden md:table-cell w-auto">
                {t(item.detail, lang)}
              </td>

            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>