---
// src/components/About.astro
import SectionHeading from './SectionHeading.astro';
import { educationHistory } from '../data/education';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ja' } = Astro.props;
---

<section id="about" class="relative border-b border-grid bg-white scroll-mt-16">
  <div class="absolute top-4 left-4 text-[10px] font-mono text-gray-400">
    SECTION: ABOUT_BIO // ID: 001
  </div>

  <div class="max-w-screen-xl mx-auto px-8 md:px-16 py-20">
    <div class="flex flex-col gap-16">

      <div class="max-w-3xl reveal">
        <SectionHeading number="01" title="About Me" />
        <div class="text-sm text-gray-600 leading-relaxed space-y-4">
          {lang === 'en' ? (
            <>
              <p>
                I'm Yushin Takahashi, a first-year master's student at the School of Computing, Institute of Science Tokyo.<br>
                After transferring from KOSEN to Hokkaido University, I moved on to Science Tokyo (formerly Tokyo Tech).
              </p>
              <p>
                My motto is "There are mysterious wins, but no mysterious losses" — I value logical thinking and the ability to implement.
              </p>
              <p>
                My graduation research at KOSEN examined the Grokking phenomenon in Transformers, and my bachelor's research simulated self-propelled particle systems.
                I currently work on graph signal processing, focusing on methods based on mathematical optimization.
              </p>
            </>
          ) : (
            <>
              <p>
                東京科学大学情報理工学院 修士1年の高橋優心です。<br>
                高専から大学編入を経て、東京科学大学 (旧:東工大) 情報理工学院に進学しました。
              </p>
              <p>
                「勝ちに不思議の勝ちあり、負けに不思議の負けなし」を座右の銘とし、論理的な思考と実装力を重視しています。
              </p>
              <p>
                高専時代の卒業研究では Transformer における Grokking 現象を、学部では自己駆動粒子系のシミュレーション研究を行っており、
                現在はグラフ信号処理を対象に、数理最適化に基づく手法の研究を行っています。
              </p>
            </>
          )}
        </div>

        <details class="mt-8 bg-gray-50 border border-grid border-l-4 border-l-primary text-sm text-gray-500 group">
          <summary class="cursor-pointer select-none p-4 font-mono text-xs text-gray-400 hover:text-primary transition-colors list-none flex items-center gap-2">
            <span class="inline-block transition-transform group-open:rotate-90" aria-hidden="true">▸</span>
            {lang === 'en'
              ? "Original passage — Matsura Seizan, Kasshi Yawa, vol. 42"
              : "出典全文: 松浦静山『甲子夜話』巻四十二"}
          </summary>
          <div class="px-4 pb-4 italic leading-relaxed">
            予曰く。勝に不思議の勝あり。負に不思議の負なし。
            問、如何なれば不思議の勝と云う。
            曰く、道を遵び術を守ときは、其の心必ず勇ならずと雖ども勝ち得る。
            是の心を顧るときは則ち不思議とす。
            故に曰ふ。又問、如何なれば不思議の負なしと云ふ。
            曰、道に背き術に違へれば、然るときは其負疑ひ無し、故に爾に云ふ、客乃伏す。
          </div>
        </details>
      </div>

      <div class="max-w-3xl reveal">
        <h3 class="text-lg font-bold mb-8 font-mono text-gray-400 flex items-center gap-2">
          <span class="w-2 h-2 bg-primary/50" aria-hidden="true"></span>
          EDUCATION_PATH
        </h3>

        <div class="relative">
          {educationHistory.map((edu, index) => (
            // pb-10で下の余白を作り、その中に線を引く (最後の項目は余白なし)
            <div class={`relative pl-10 ${index !== educationHistory.length - 1 ? 'pb-10' : ''}`}>
              
              {index !== educationHistory.length - 1 && (
                <div 
                  class={`absolute left-2 top-2 h-full w-[2px] -translate-x-1/2 z-0
                    ${edu.status === 'Incoming' ? 'bg-gray-200' : 'bg-primary'}`}
                ></div>
              )}

              <div class="absolute left-2 top-1.5 -translate-x-1/2 z-10" aria-hidden="true">
                {edu.status === 'Incoming' && (
                  // 進学予定: 白抜き + 枠線
                  <div class="w-4 h-4 rounded-full bg-white border-2 border-primary box-content"></div>
                )}
                {edu.status === 'Current' && (
                  // 在学中: 塗りつぶし + 強調リング (Pulse)
                  <div class="relative w-4 h-4">
                    <div class="absolute inset-0 rounded-full bg-primary animate-pulse opacity-30 scale-150"></div>
                    <div class="relative w-4 h-4 rounded-full bg-primary border-2 border-white ring-1 ring-primary"></div>
                  </div>
                )}
                {edu.status === 'Graduated' && (
                  // 卒業: シンプルな塗りつぶし
                  <div class="w-4 h-4 rounded-full bg-primary border-2 border-white"></div>
                )}
              </div>

              <span class={`font-mono text-xs block mb-1 ${edu.status === 'Graduated' ? 'text-gray-400' : 'text-primary font-bold'}`}>
                {edu.period}
              </span>

              <h4 class="text-base font-bold text-text">
                {edu.school}
              </h4>
              <div class="text-xs text-gray-500 mb-2">{edu.schoolJa}</div>

              <div class="bg-gray-50 border border-grid rounded px-3 py-2 inline-block">
                 <div class="text-sm font-medium text-gray-700">{edu.dept}</div>
                 <div class="text-xs text-gray-400 mt-0.5">{edu.deptJa}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>