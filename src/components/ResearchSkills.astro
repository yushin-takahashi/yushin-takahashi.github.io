---
import SectionHeading from './SectionHeading.astro';

const researchTopics = [
  {
    id: "01",
    area: "Graph Signal Processing / Graph Learning",
    detail: "現在の主な関心領域。グラフ信号処理、特にグラフ学習に興味を持っている。",
    status: "Current Focus"
  },
  {
    id: "02",
    area: "Statistical Mechanics / Collective Motion",
    detail: "学士課程では、自己駆動粒子系における非相反作用と集団運動のダイナミクスを解析。統計力学的なモデリングの視点を培った。",
    status: "Past Research"
  },
  {
    id: "03",
    area: "Deep Learning Dynamics",
    detail: "準学士課程では、ニューラルネットワークの学習ダイナミクスそのものを対象に、Grokking現象の解析に取り組んだ。",
    status: "Past Research"
  }
];

// 習熟度カテゴリ (パーセント表記は廃止し、簡潔なバッジ表記に統一)
const technicalSkills = [
  { name: "Python (PyTorch, NumPy, Pandas)", level: "PRIMARY" },
  { name: "MATLAB", level: "WORKING" },
  { name: "C, C++, C#", level: "WORKING" },
  { name: "Machine Learning / Data Science", level: "WORKING" },
  { name: "Mathematical Modeling / Simulation", level: "WORKING" }
];
---

<section id="skills" class="relative border-b border-grid bg-white scroll-mt-16">
  <div class="absolute top-4 right-4 text-[10px] font-mono text-gray-400">
    SECTION: CAPABILITIES // ID: 002
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2">

    <div class="p-8 md:p-16 border-b md:border-b-0 md:border-r border-grid reveal">
      <SectionHeading number="02.a" title="Research Interests" class="mb-10" />

      <div class="space-y-8">
        {researchTopics.map((topic) => (
          <div class="group">
            <div class="flex items-center justify-between mb-2 gap-4">
              <h3 class="text-lg font-bold group-hover:text-primary transition-colors">
                {topic.area}
              </h3>
              <span class="font-mono text-xs text-primary border border-primary px-2 py-0.5 rounded-full opacity-70 whitespace-nowrap text-center">
                {topic.status}
              </span>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed pl-4 border-l-2 border-grid group-hover:border-primary transition-colors">
              {topic.detail}
            </p>
          </div>
        ))}
      </div>
    </div>

    <div class="p-8 md:p-16 bg-gray-50/50 reveal">
      <SectionHeading number="02.b" title="Engineering Stack" class="mb-10" />
      <div class="space-y-4 mt-2">
        {technicalSkills.map((skill) => (
          <div class="flex items-center gap-3 font-mono text-xs">
            <span class={`px-2 py-0.5 border rounded-[2px] tracking-wider whitespace-nowrap
              ${skill.level === 'PRIMARY'
                ? 'text-primary border-primary bg-primary/5'
                : 'text-gray-500 border-gray-300 bg-white'}`}>
              {skill.level}
            </span>
            <span class="text-gray-700">{skill.name}</span>
          </div>
        ))}
      </div>
      <div class="mt-12 pt-8 border-t border-dashed border-gray-300">
        <p class="font-mono text-xs text-gray-400 mb-4">OTHER TOOLS & ENVIRONMENTS:</p>
        <div class="flex flex-wrap gap-2">
          {["Git/GitHub", "VS Code", "LaTeX"].map((tool) => (
            <span class="text-xs border border-gray-300 px-3 py-1 text-gray-600 bg-white">
              {tool}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>