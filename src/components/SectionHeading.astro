---
// src/components/SectionHeading.astro
// 各セクション共通の見出しコンポーネント。番号ラベル + タイトルの表示を一元化する。

interface Props {
	number: string;
	title: string;
	class?: string;
}

const { number, title, class: className = "mb-8" } = Astro.props;
---

<h2 class:list={["text-2xl font-bold flex items-center gap-3", className]}>
	<span class="text-primary font-mono text-lg">{number}.</span>
	{title}
</h2>
