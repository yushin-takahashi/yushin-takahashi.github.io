---
import SectionHeading from './SectionHeading.astro';
import { projects } from '../data/projects';
import { t, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ja' } = Astro.props;
---

<section id="works" class="relative border-b border-grid bg-base scroll-mt-16">
  <div class="absolute top-4 left-4 text-[10px] font-mono text-gray-400">
    SECTION: WORKS // ID: 003
  </div>

  <div class="max-w-screen-xl mx-auto px-8 md:px-16 py-20 reveal">
    <SectionHeading number="03" title="Selected Works" class="mb-12" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => {
        const hasLinks = project.links.length > 0;

        return (
          <div class="group block h-full bg-white border border-grid hover:border-primary transition-colors relative overflow-hidden">
            <div class="flex justify-between items-center px-6 py-3 border-b border-grid bg-gray-50/50">
              <span class="flex items-baseline gap-2">
                <span class="font-mono text-xs text-primary">{project.id}</span>
                <span class="font-mono text-[10px] text-gray-400">{project.date}</span>
              </span>
              <span class="font-mono text-[10px] text-gray-400 uppercase tracking-wider">{project.category}</span>
            </div>

            <div class="p-6 md:p-8">
              <h3 class="text-xl font-bold mb-3 text-text group-hover:text-primary transition-colors">
                {t(project.title, lang)}
              </h3>

              <div class="flex flex-wrap gap-2 mb-4">
                {project.tech.map((t) => (
                  <span class="text-[10px] border border-gray-200 px-2 py-1 text-gray-500 font-mono">
                    {t}
                  </span>
                ))}
              </div>

              <p class="text-sm text-gray-600 leading-relaxed mb-4">
                {t(project.description, lang)}
              </p>

              {project.milestones && project.milestones.length > 0 && (
                <div class="flex flex-wrap gap-x-3 gap-y-1 mb-4 font-mono text-[10px] text-gray-400">
                  {project.milestones.map((m) => (
                    <span>{t(m.label, lang)}: {m.date}</span>
                  ))}
                </div>
              )}

              {hasLinks ? (
                <div class="flex flex-wrap gap-x-4 gap-y-1 pt-4 border-t border-dashed border-gray-200">
                  {project.links.map((l) => (
                    l.url ? (
                      <a href={l.url} target="_blank" rel="noopener noreferrer" class="text-xs font-bold text-primary hover:underline underline-offset-4 flex items-center gap-1 font-mono">
                        {t(l.label, lang)} <span aria-hidden="true">→</span>
                      </a>
                    ) : (
                      <span class="text-xs text-gray-400 flex items-center gap-1 font-mono">
                        {t(l.label, lang)}
                      </span>
                    )
                  ))}
                </div>
              ) : (
                <div class="font-mono text-[10px] text-gray-400 pt-4 border-t border-dashed border-gray-200">
                  LINK: N/A
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>